namespace Azubi_Einsatzplaner
{
    public partial class Calender : System.Web.UI.Page
    {
        // Datenbank Connection
        readonly string _gConnectStr = @"Provider=Microsoft.Jet.OLEDB.4.0;Data Source=C:\Temp\Azubi_Einsatzplaner\Azubi_Einsatzplaner.mdb;Persist Security Info=False";
        readonly ADODB.Connection _conn1 = new ADODB.Connection();

        // Farben für die Abwesenheiten
        private Color feiertagColor = Color.FromArgb(102, 206, 224);
        private Color wochenendeColor = Color.FromArgb(186, 182, 147);
        private Color berufsschuleColor = Color.FromArgb(255, 203, 5);
        private Color urlaubColor = Color.FromArgb(162, 205, 3);
        private Color einsatzColor = Color.FromArgb(227, 226, 213);
        private Color ferienColor = Color.FromArgb(192, 229, 235);
        private Color headerColor = Color.FromArgb(4, 149, 197);

        Berechtigungen berechtigung = new Berechtigungen();
        string admin = "gramatzk";

        protected void Page_Init(object sender, EventArgs e)
        {
            
            // Überprüfen, ob Year-Parameter übergeben wurde
            if (Request.QueryString["year"] != null)
            {
                Berechtigungen berechtigung = new Berechtigungen();

                if (berechtigung.CheckUserRights(Request.QueryString["azubi"]))
                {
                    // Jahr in eine Variable schreiben
                    int year = Convert.ToInt32(Request.QueryString["year"]);

                    // Zwischenspeichern für Seitenaktualisierungen
                    ViewState["Year"] = year;

                    // Übersichten laden
                    AzubiData_Load(year);
                    Fachbereiche_Load();
                    CreateLegend();
                }
                else
                {
                    ux_todaysYearLabel.Text = "Sie haben keine Rechte um auf diesen Kalender zuzugreifen.";
                    ux_todaysYearLabel.ForeColor = Color.Red;
                    ux_nextYearButton.Enabled = false;
                    ux_previousYearButton.Enabled = false;
                    ux_saveBtton.Enabled = false;
                    ux_EinsatzDatumAnfang.Enabled = false;
                    ux_EinsatzDatumEnde.Enabled = false;
                    ux_AbteilungenDropDown.Enabled = false;

                }
            } else
            {
                // An die GesamtAnsicht weiterleiten
                Response.Redirect("GesamtAnsicht.aspx");
            }
        }
        protected void Page_Load(object sender, EventArgs e)
        {

        }

        // Ausgewählten Azubi auslesen 
        private void AzubiData_Load(int year)
        {
            // Überprüfen, ob Year-Parameter übergeben wurde
            if (Request.QueryString["azubi"] != null)
            {
                _conn1.Open(_gConnectStr);
                ADODB.Recordset rs1 = new ADODB.Recordset();
                
                // Informationen des Azubis auslesen und darstellen
                rs1.Open("SELECT * FROM Auszubildender WHERE kuerzel ='" + Request.QueryString["azubi"] + "'", _conn1, ADODB.CursorTypeEnum.adOpenForwardOnly, ADODB.LockTypeEnum.adLockOptimistic);

                // Labels beschreiben
                ux_vornameLabel.Text = rs1.Fields["Vorname"].Value.ToString();
                ux_nachnameLabel.Text = rs1.Fields["Nachname"].Value.ToString();
                ux_fachrichtungLabel.Text = rs1.Fields["Fachrichtung"].Value.ToString();
                ux_jahrgangLabel.Text = rs1.Fields["Jahrgang"].Value.ToString();
                ux_turnusLabel.Text = rs1.Fields["Turnus"].Value.ToString();

                // Schließen der Datenbankverbindung
                rs1.Close();
                _conn1.Close();

                // Kalender des entsprechenden Azubis im ausgewählten Jahr erzeugen
                CreateCalendar(year);
            }
            else
            {
                // An die GesamtAnsicht weiterleiten
                Response.Redirect("GesamtAnsicht.aspx");
            }
        }

        // Fachbereiche in das DropDown schreiben
        private void Fachbereiche_Load()
        {
            ux_AbteilungenDropDown.Items.Clear();
            _conn1.Open(_gConnectStr);
            ADODB.Recordset rs1 = new ADODB.Recordset();

            // Alle Abteilungen auslesen und in Dropdown schreiben
            rs1.Open("SELECT * FROM Abteilung;", _conn1, ADODB.CursorTypeEnum.adOpenForwardOnly, ADODB.LockTypeEnum.adLockOptimistic);

            // Leeres Auswahlelement erzeugen
            ux_AbteilungenDropDown.Items.Add(new ListItem(""));
            // Urlaubsauswahl erzeugen
            ux_AbteilungenDropDown.Items.Add(new ListItem("Urlaub"));

            if (berechtigung.GetUser() == admin)
            {
                while (!rs1.EOF)
                {
                    // Fachbereich der Liste/Dropdown hinzufügen
                    ux_AbteilungenDropDown.Items.Add(new ListItem(rs1.Fields["Abteilung"].Value.ToString()));
                    rs1.MoveNext();
                }
            }
            // Schließen der Datenbankverbindung
            rs1.Close();
            _conn1.Close();
        }

        // Kalenderansicht erstellen (Alle Tage im Jahr)
        private void CreateCalendar(int year)
        {            
            // Alle Listen erzeugen
            List<DateTime> feiertage = FeiertageBerechnen(year); 
            List<Einsatz> berufsschule = GetTagesRange("Berufsschule");
            List<Einsatz> urlaub = GetTagesRange("Urlaub");
            List<Einsatz> einsaetze = GetTagesRange("Einsatz");
            List<Einsatz> ferien = GetTagesRange("Ferien");
            List<Einsatz> brueckentag = GetTagesRange("Brueckentag");

            int i = 0;

            // Vorherige Anzeigen löschen
            ux_calendarTable.Rows.Clear();

            // Ausgewähltes Jahr darstellen
            ux_todaysYearLabel.Text = year.ToString();

            // Überschriften für die Spalten der Monate
            TableRow headerRow = new TableRow();
            for (int month = 1; month <= 12; month++)
            {
                TableCell headerCell = new TableCell();
                CheckBox checkBox = new CheckBox();

                checkBox.ID = month.ToString();
                checkBox.Text = GetMonthName(month);
                checkBox.Font.Bold = true;
                // Setze die AutoPostBack-Eigenschaft auf true, damit die Seite zurück zum Server gesendet wird, wenn sich die Auswahl der CheckBox ändert
                checkBox.AutoPostBack = true;
                // Füge einen Event-Handler für das CheckedChanged-Event hinzu
                checkBox.CheckedChanged += new EventHandler(ShowDatumOnTextBoxen);

                headerCell.Controls.Add(checkBox);

                headerCell.BackColor = headerColor;
                headerCell.HorizontalAlign = HorizontalAlign.Center;
                headerRow.Cells.Add(headerCell);
            }
            ux_calendarTable.Rows.Add(headerRow);

            // Reihen für jeden Tag erstellen
            for (int day = 1; day <= 31; day++)
            {
                TableRow dayRow = new TableRow();

                // Jede Spalte der Monate durchgehen
                for (int month = 1; month <= 12; month++)
                {
                    TableCell dayCell = new TableCell();

                    //Überprüfen ob Reihenzahl noch innerhalb der Anzahl der Tage im Monat liegt
                    if (day <= DateTime.DaysInMonth(year, month))
                    {
                        //Datum in die Zelle schreiben
                        DateTime todaysDate = new DateTime(year, month, day);
                        String dayOfWeek = GetDayOfWeek(year, month, day);
                        dayCell.Text = day + " " + dayOfWeek.Substring(0, 2);

                        // Ferien farbig markieren
                        foreach (Einsatz einsatz in ferien)
                        {
                            if (einsatz.Datum == todaysDate)
                            {
                                dayCell.BackColor = ferienColor;
                            }
                        }

                        // Brückentage farbig markieren
                        foreach (Einsatz einsatz in brueckentag)
                        {
                            if (einsatz.Datum == todaysDate)
                            {
                                dayCell.BackColor = ferienColor;
                            }
                        }

                        // Einsätze farbig markieren
                        foreach (Einsatz einsatz in einsaetze)
                        {
                            if (einsatz.Datum == todaysDate)
                            {
                                dayCell.BackColor = einsatzColor;
                                //dayCell.ID = "Einsatz_" + einsatz.ID.ToString() + "_" + i;
                                //i++;

                                LinkButton linkButton = new LinkButton();
                                linkButton.BackColor = einsatzColor;
                                linkButton.ID = "Einsatz_" + einsatz.ID.ToString() + "_" + i;
                                i++;

                                if (einsatz.Abteilung.Length > 3)
                                {
                                    // Einsatznamen kürzen falls nötig auf nur 3 Buchstaben
                                    //dayCell.Text += " (" + einsatz.Abteilung.Substring(0, 3) + ")";
                                    linkButton.Text = dayCell.Text + " (" + einsatz.Abteilung.Substring(0, 3) + ")";
                                } else
                                {
                                    //dayCell.Text += " (" + einsatz.Abteilung + ")";
                                    linkButton.Text = dayCell.Text + " (" + einsatz.Abteilung + ")";
                                }

                                if (berechtigung.GetUser() == admin)
                                {
                                    linkButton.Click += GetEinsatz;
                                }                               
                                linkButton.ForeColor = Color.Black;
                                linkButton.Attributes["style"] = "text-decoration: none;";
                                dayCell.Controls.Add(linkButton);
                            }
                        }

                        // Urlaub farbig markieren
                        foreach (Einsatz einsatz in urlaub)
                        {
                            if (einsatz.Datum == todaysDate)
                            {
                                dayCell.Controls.Clear();
                                dayCell.BackColor = urlaubColor;
                                //dayCell.ID = "Urlaub_" + einsatz.ID.ToString() + "_" + i;
                                //i++;
                                //dayCell.Text = day + " " + dayOfWeek.Substring(0, 3) + " (Ur)";

                                LinkButton linkButton = new LinkButton();
                                linkButton.BackColor = urlaubColor;
                                linkButton.ID = "Urlaub_" + einsatz.ID.ToString() + "_" + i;
                                i++;
                                linkButton.Text = day + " " + dayOfWeek.Substring(0, 2) + " (Ur)";
                                linkButton.Click += GetEinsatz;
                                linkButton.ForeColor = Color.Black;
                                linkButton.Attributes["style"] = "text-decoration: none;";
                                dayCell.Controls.Add(linkButton);
                            }
                        }

                        // Berufsschule farbig markieren
                        foreach (Einsatz einsatz in berufsschule)
                        {
                            if (einsatz.Datum == todaysDate)
                            {
                                dayCell.BackColor = berufsschuleColor;
                                dayCell.Text = day + " " + dayOfWeek.Substring(0, 2) + " (OSZ)";
                            }
                        }

                        // Feiertage farbig markieren
                        foreach (DateTime datum in feiertage)
                        {
                            if (datum == todaysDate)
                            {
                                dayCell.BackColor = feiertagColor;
                                dayCell.Text = day + " " + dayOfWeek.Substring(0, 2);
                            }
                        }

                        // Wochenenden farbig markieren
                        if (dayOfWeek == "Samstag" || dayOfWeek == "Sonntag")
                        {
                            dayCell.BackColor = wochenendeColor;
                            dayCell.Text = day + " " + dayOfWeek.Substring(0, 2);
                        }
                    }                 
                    dayCell.HorizontalAlign = HorizontalAlign.Center;
                    dayRow.Cells.Add(dayCell);
                }
                ux_calendarTable.Rows.Add(dayRow);
            }
        }

        private void GetEinsatz(object sender, EventArgs e)
        {
            LinkButton clickedButton = (LinkButton)sender;
            string idCell = clickedButton.ID.ToString();

            string[] idStrings = idCell.Split('_');

            string tabelle = idStrings[0];
            string id = idStrings[1];

            _conn1.Open(_gConnectStr);
            ADODB.Recordset rs1 = new ADODB.Recordset();

            // Einsatz auslesen per ID
            string anfrage = "SELECT * FROM " + tabelle + " WHERE ID = " + id + " ;";
            rs1.Open(anfrage, _conn1, ADODB.CursorTypeEnum.adOpenForwardOnly, ADODB.LockTypeEnum.adLockOptimistic);
            string abteilung = "";

            if (tabelle == "Einsatz")
            {
                abteilung = rs1.Fields["ID_Abteilung"].Value.ToString();
            }
            else if (tabelle == "Urlaub")
            {
                abteilung = "Urlaub";
            }


            ux_EinsatzDatumAnfang.Text = rs1.Fields["Anfangsdatum"].Value.ToString("dd.MM.yyyy");
            ux_EinsatzDatumEnde.Text = rs1.Fields["Enddatum"].Value.ToString("dd.MM.yyyy");
            ux_idLabel.Text = tabelle + "_" + rs1.Fields["ID"].Value.ToString() + "_" + abteilung;

            // Schließen der Datenbankverbindung
            rs1.Close();
            _conn1.Close();

            // Abteilung einsetzen
            Fachbereiche_Load();
            ux_AbteilungenDropDown.SelectedValue = abteilung;

            ux_saveBtton.Visible = false;
            ux_saveBtton.Enabled = false;
            ux_EditSaveButton.Visible = true;
            ux_EditSaveButton.Enabled = true;           
            
        }

        private void ShowDatumOnTextBoxen(object sender, EventArgs e)
        {
            CheckedChanged();
        }

        private void CheckedChanged()
        {
            int year = (int)ViewState["Year"];
            int kleinsterMonat = 12;
            int groessterMonat = 1;
            List<CheckBox> checkBoxList = new List<CheckBox>();

            // Durchlaufe die erste Zeile der Tabelle
            TableRow headerRow = ux_calendarTable.Rows[0];
            foreach (TableCell cell in headerRow.Cells)
            {
                // Überprüfe, ob die Zelle ein CheckBox-Steuerelement enthält
                if (cell.Controls.Count > 0 && cell.Controls[0] is CheckBox)
                {
                    // Lese die CheckBox aus
                    CheckBox checkBox = (CheckBox)cell.Controls[0];
                    int id = int.Parse(checkBox.ID);

                    // Wenn die CheckBox bereits ausgewählt ist, füge sie der Liste hinzu
                    if (checkBox.Checked)
                    {
                        checkBoxList.Add(checkBox);
                    }
                    // Wenn die ID zwischen kleinsterMonat und groessterMonat liegt, selektiere die CheckBox
                    else if (id >= kleinsterMonat && id <= groessterMonat)
                    {
                        checkBox.Checked = true;
                        checkBoxList.Add(checkBox);
                    }
                }
            }
            foreach (CheckBox checkbox in checkBoxList)
            {
                int id = int.Parse(checkbox.ID);

                if (id >= groessterMonat)
                {
                    groessterMonat = id;
                }
                if (id <= kleinsterMonat)
                {
                    kleinsterMonat = id;
                }

            }

            if (checkBoxList.Count == 0)
            {
                ux_EinsatzDatumAnfang.Enabled = true;
                ux_EinsatzDatumEnde.Enabled = true;
            } else
            {
                DateTime anfang = new DateTime(year, kleinsterMonat, 1);
                int tageImMonat = DateTime.DaysInMonth(year, groessterMonat);
                DateTime ende = new DateTime(year, groessterMonat, tageImMonat);

                ux_EinsatzDatumAnfang.Text = anfang.ToString("dd.MM.yyyy");
                ux_EinsatzDatumEnde.Text = ende.ToString("dd.MM.yyyy");
                ux_EinsatzDatumAnfang.Enabled = false;
                ux_EinsatzDatumEnde.Enabled = false;
            }
        }

        // Liste der Einsätze mit einer Range erstellen
        private List<Einsatz> GetTagesRange(string art)
        {
            List<Einsatz> allEinsaetze = new List<Einsatz>();
            string anfrage;
            DateTime anfangsdatum;
            DateTime enddatum;

            _conn1.Open(_gConnectStr);
            ADODB.Recordset rs1 = new ADODB.Recordset();

            // Auswahl welche Liste man erstellen möchte -> dementsprechende Selection
            switch (art)
            {
                case "Berufsschule":
                    anfrage = "SELECT * FROM Berufsschule INNER JOIN Auszubildender ON Berufsschule.Bezeichnung = Auszubildender.Turnus WHERE Auszubildender.kuerzel = '" + Request.QueryString["azubi"] + "';" ;
                    break;
                case "Urlaub":
                    anfrage = "SELECT * FROM " + art + " WHERE kuerzel_Auszubildender = '" + Request.QueryString["azubi"] + "';";
                    break;
                case "Einsatz":
                    anfrage = "SELECT * FROM " + art + " WHERE kuerzel_Auszubildender = '" + Request.QueryString["azubi"] + "';";
                    break;
                case "Ferien":
                    anfrage = "SELECT * FROM " + art + ";";
                    break;
                case "Brueckentag":
                    anfrage = "SELECT * FROM Brueckentag INNER JOIN Auszubildender ON Brueckentag.Bezeichnung = Auszubildender.Turnus WHERE Auszubildender.kuerzel = '" + Request.QueryString["azubi"] + "';";
                    break;
                default:
                    anfrage = "";
                    break;
            }
            // Alle Einsätze des ausgewählten Azubis abrufen
            rs1.Open(anfrage, _conn1, ADODB.CursorTypeEnum.adOpenForwardOnly, ADODB.LockTypeEnum.adLockOptimistic);

            while (!rs1.EOF)
            {
                anfangsdatum = rs1.Fields["Anfangsdatum"].Value;
                enddatum = rs1.Fields["Enddatum"].Value;
                string abteilung;
                int id = rs1.Fields["ID"].Value;

                // Auswahl welche Liste man erstellen möchte -> dementsprechende Selection
                switch (art)
                {
                    case "Berufsschule":
                        abteilung = rs1.Fields["Bezeichnung"].Value.ToString();
                        break;
                    case "Urlaub":
                        abteilung = rs1.Fields["kuerzel_Auszubildender"].Value.ToString();
                        break;
                    case "Einsatz":
                        abteilung = rs1.Fields["ID_Abteilung"].Value.ToString();
                        break;
                    case "Ferien":
                        abteilung = rs1.Fields["Bezeichnung"].Value.ToString();
                        break;
                    case "brueckentag":
                        abteilung = rs1.Fields["Bezeichnung"].Value.ToString();
                        break;
                    default:
                        abteilung = "";
                        break;
                }

                // Die Zeitspanne der Range füllen
                List<Einsatz> allTagesEinsaetze = FillTage(anfangsdatum, enddatum, abteilung, id);

                // Listen aneinanderfügen für spätere Ausgabe
                allEinsaetze.AddRange(allTagesEinsaetze);

                rs1.MoveNext();
            }

            // Schließen der Datenbankverbindung
            rs1.Close();
            _conn1.Close();

            return allEinsaetze;
        }

        // Die Tage der Range erzeugen
        private List<Einsatz> FillTage(DateTime anfangsdatum, DateTime enddatum, string abteilung, int id)
        {
            List<Einsatz> allTagesEinsaetze = new List<Einsatz>();

            // Die Tage zwischen Anfangs- und Enddatum erstellen und zu einer Liste hinzufügen
            // So können alle Tage des Einsatzes markiert werden
            for (DateTime date = anfangsdatum; date <= enddatum; date = date.AddDays(1))
            {
                Einsatz tagesEinsatz = new Einsatz();
                tagesEinsatz.Datum = date;
                tagesEinsatz.Abteilung = abteilung;
                tagesEinsatz.Kuerzel = Request.QueryString["azubi"];
                tagesEinsatz.ID = id;
                allTagesEinsaetze.Add(tagesEinsatz);
            }
            return allTagesEinsaetze;
        }

        // Überprüft ob die Einsätze in einen anderen Einsatz fallen
        // gbt die Datumsangaben zurück wo das der fall ist
        private List<Einsatz> CheckAllDays (List<Einsatz> einsaetze)
        {
            List<Einsatz> belegteEinsaetze = new List<Einsatz>();

            foreach (Einsatz einsatz in einsaetze)
            {
                if (einsatz.CheckEinsatz())
                {
                    belegteEinsaetze.Add(einsatz);
                }
            }
            return belegteEinsaetze;
        }

