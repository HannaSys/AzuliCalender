        // Das ausgewählte Jahr vermindern und dann anzeigen
        protected void ux_previousYearButton_Click(object sender, EventArgs e)
        {
            // Jahresvariable aus dem Viewstate entnehmen und neu speichern
            int year = (int)ViewState["Year"];
            year--;
            ViewState["Year"] = year;
            CreateCalendar(year);
        }

        // Das ausgewählte Jahr erhöhen und dann anzeigen
        protected void ux_nextYearButton_Click(object sender, EventArgs e)
        {
            // Jahresvariable aus dem Viewstate entnehmen und neu speichern
            int year = (int)ViewState["Year"];
            year++;
            ViewState["Year"] = year;
            CreateCalendar(year);
        } 

        // Exportiert die Einsatzdaten aller Azubis der nächsten zwei Jahre
        protected void ux_exportButton_Click(object sender, EventArgs e)
        {
            Export export = new Export();
            export.SingleExportxlsx(Request.QueryString["azubi"]);
        }

        // Speichert bzw löscht die Einträge 
        protected void ux_saveBtton_Click(object sender, EventArgs e)
        {                
            CheckedChanged();
            // Liste für die Tage des angegebenen Zeitraums
            List<Einsatz> alleDaten = new List<Einsatz>();
            string anfang = ux_EinsatzDatumAnfang.Text;
            string ende = ux_EinsatzDatumEnde.Text;

            // Anfangsdatum und Enddatum müssen angegeben sein
            if (anfang != "" && ende != "")
            {
                string abteilung = ux_AbteilungenDropDown.SelectedValue;
                try
                {
                    if (DateTime.Parse(ux_EinsatzDatumAnfang.Text).GetType() == typeof(DateTime) && DateTime.Parse(ux_EinsatzDatumAnfang.Text).GetType() == typeof(DateTime))
                    {
                        DateTime anfangsdatum = DateTime.Parse(ux_EinsatzDatumAnfang.Text);
                        DateTime enddatum = DateTime.Parse(ux_EinsatzDatumEnde.Text);

                        // Datumsangaben tauschen bei vertauschter angabe
                        if (enddatum < anfangsdatum)
                        {
                            DateTime tmp;
                            tmp = anfangsdatum;
                            anfangsdatum = enddatum;
                            enddatum = tmp;
                        }

                        // Zeitraum befüllen
                        alleDaten = FillTage(anfangsdatum, enddatum, abteilung, 0);
                        // Überprüfen ob kein anderer Einsatz in den Zeitraum stattfindet
                        alleDaten = CheckAllDays(alleDaten);

                        // falls ein anderer Einsatz sich überschneidet ist bei der Liste min 1 Element
                        if (alleDaten.Count >= 1)
                        {
                            // Wenn die Abteilung leer ist soll der Zeitraum bzw stattfindende Einsätze gelöscht werden
                            if (abteilung == "")
                            {
                                foreach (Einsatz einsatz in alleDaten)
                                {
                                    einsatz.DeleteEinsatz(einsatz.Datum, "Urlaub");
                                    einsatz.DeleteEinsatz(einsatz.Datum, "Einsatz");
                                }
                                ux_FehlermeldungLabel.Visible = false;
                            }
                            // Falls nicht dann könnt eine Fehlermeldung für den User
                            else
                            {
                                ux_FehlermeldungLabel.Visible = true;
                                ux_FehlermeldungLabel.Text = "Zu der Zeit findet ein anderer Einsatz statt.";
                                ux_FehlermeldungLabel.ForeColor = Color.Red;
                            }

                            // wenn keine anderen Einsätze in dem Zeitraum sind dann wird der Einsatz gespeichert
                        }
                        else
                        {
                            // Überprüfen ob eine Abteilung ausgewählt wurde
                            if (abteilung != "")
                            {
                                _conn1.Open(_gConnectStr);
                                ADODB.Recordset rs1 = new ADODB.Recordset();
                                string anfrage;

                                // Die richtige Datenbank aufrufen
                                switch (abteilung)
                                {
                                    case "Urlaub":
                                        anfrage = "SELECT * FROM Urlaub WHERE Anfangsdatum IS NULL;";
                                        break;
                                    default:
                                        anfrage = "SELECT * FROM Einsatz WHERE Anfangsdatum IS NULL;";
                                        break;
                                }
                                // Leeren Datensatz erzeugen
                                rs1.Open(anfrage, _conn1, ADODB.CursorTypeEnum.adOpenForwardOnly, ADODB.LockTypeEnum.adLockOptimistic);

                                // Daten in den leeren Satz schreiben
                                rs1.AddNew();
                                rs1.Fields["Anfangsdatum"].Value = anfangsdatum;
                                rs1.Fields["Enddatum"].Value = enddatum;

                                // Felder den Datenbanken angepasst speichern
                                switch (abteilung)
                                {
                                    case "Urlaub":
                                        rs1.Fields["kuerzel_Auszubildender"].Value = Request.QueryString["azubi"];
                                        break;
                                    default:
                                        rs1.Fields["ID_Abteilung"].Value = abteilung;
                                        rs1.Fields["kuerzel_Auszubildender"].Value = Request.QueryString["azubi"];
                                        break;
                                }

                                // Updaten und schließen der Datenbankverbindung
                                rs1.Update();
                                rs1.Close();
                                _conn1.Close();

                                ux_FehlermeldungLabel.Enabled = false;

                                // Bei keiner ausgewählten Abteilung kommt Fehlermeldung für den User
                            }
                            else
                            {
                                ux_FehlermeldungLabel.Visible = true;
                                ux_FehlermeldungLabel.Text = "Bitte alle Felder ausfüllen.";
                                ux_FehlermeldungLabel.ForeColor = Color.Red;
                            }
                        }
                    }
                } catch (FormatException)
                {
                    ux_FehlermeldungLabel.Visible = true;
                    ux_FehlermeldungLabel.Text = "Fehler: Ungültiges Datum";
                }
                

            // Falls es keine Datumsangaben gab kommt Fehlermeldung für den User
            }
            else
            {
                ux_FehlermeldungLabel.Visible = true;
                ux_FehlermeldungLabel.Text = "Bitte alle Felder ausfüllen.";
                ux_FehlermeldungLabel.ForeColor = Color.Red;
            }
            ux_EinsatzDatumAnfang.Enabled = true;
            ux_EinsatzDatumEnde.Enabled = true;
            // Kalender und Azubi werden neu geladen
            int year = (int)ViewState["Year"];
            AzubiData_Load(year);
        }

        protected void ux_EditSaveButton_Click(object sender, EventArgs e)
        { 
            string[] idStrings = ux_idLabel.Text.Split('_');
            string tabelle = idStrings[0];
            string id = idStrings[1];
            string abteilung = idStrings[2];

            _conn1.Open(_gConnectStr);
            ADODB.Recordset rs1 = new ADODB.Recordset();


            try
            {
                // Wenn der Einsatz gleich bleibt nur die Datumangaben speichern/ändern
                if (ux_AbteilungenDropDown.SelectedValue.ToString() == abteilung)
                {
                    // Einsatz auslesen per ID
                    string anfrage = "SELECT * FROM " + tabelle + " WHERE ID = " + id + " ;";
                    rs1.Open(anfrage, _conn1, ADODB.CursorTypeEnum.adOpenForwardOnly, ADODB.LockTypeEnum.adLockOptimistic);
                    rs1.Fields["Anfangsdatum"].Value = ux_EinsatzDatumAnfang.Text;
                    rs1.Fields["Enddatum"].Value = ux_EinsatzDatumEnde.Text;

                    // Schließen der Datenbankverbindung
                    rs1.Update();
                    rs1.Close();
                    _conn1.Close();
                }
                // Falls der Einsatz gelöscht werden soll
                else if (ux_AbteilungenDropDown.SelectedValue.ToString() == "")
                {
                    // Einsatz auslesen per ID
                    string anfrage = "SELECT * FROM " + tabelle + " WHERE ID = " + id + " ;";
                    rs1.Open(anfrage, _conn1, ADODB.CursorTypeEnum.adOpenForwardOnly, ADODB.LockTypeEnum.adLockOptimistic);
                    // Einsatz löschen aus anderer Tabelle
                    rs1.Delete();

                    // Schließen der Datenbankverbindung
                    rs1.Update();
                    rs1.Close();
                    _conn1.Close();

                }
                // Falls der Einsatz nun Urlaub ist und vorher etwas anderes
                else if (ux_AbteilungenDropDown.SelectedValue.ToString() == "Urlaub" && ux_AbteilungenDropDown.SelectedValue.ToString() != abteilung)
                {
                    // Einsatz auslesen per ID
                    string anfrage = "SELECT * FROM " + tabelle + " WHERE ID = " + id + " ;";
                    rs1.Open(anfrage, _conn1, ADODB.CursorTypeEnum.adOpenForwardOnly, ADODB.LockTypeEnum.adLockOptimistic);
                    // Einsatz löschen aus anderer Tabelle
                    rs1.Delete();

                    // Schließen der Datenbankverbindung
                    rs1.Update();
                    rs1.Close();
                    _conn1.Close();

                    tabelle = "Urlaub";
                    anfrage = "SELECT * FROM " + tabelle + " WHERE Anfangsdatum IS NULL ;";
                    rs1.Open(anfrage, _conn1, ADODB.CursorTypeEnum.adOpenForwardOnly, ADODB.LockTypeEnum.adLockOptimistic);
                    rs1.AddNew();
                    rs1.Fields["Anfangsdatum"].Value = ux_EinsatzDatumAnfang.Text;
                    rs1.Fields["Enddatum"].Value = ux_EinsatzDatumEnde.Text;
                    rs1.Fields["kuerzel_Auszubildender"].Value = Request.QueryString["azubi"];

                    // Schließen der Datenbankverbindung
                    rs1.Update();
                    rs1.Close();
                    _conn1.Close();
                }
                // Wenn der Einsatz von Urlaub zu einer Abteilung verändert wurde
                else if (ux_AbteilungenDropDown.SelectedValue.ToString() != "Urlaub" && "Urlaub" == abteilung)
                {
                    // Einsatz auslesen per ID
                    string anfrage = "SELECT * FROM Urlaub WHERE ID = " + id + " ;";
                    rs1.Open(anfrage, _conn1, ADODB.CursorTypeEnum.adOpenForwardOnly, ADODB.LockTypeEnum.adLockOptimistic);
                    rs1.Delete();

                    // Schließen der Datenbankverbindung
                    rs1.Update();
                    rs1.Close();
                    _conn1.Close();

                    tabelle = "Einsatz";
                    anfrage = "SELECT * FROM " + tabelle + " WHERE Anfangsdatum IS NULL ;";
                    rs1.Open(anfrage, _conn1, ADODB.CursorTypeEnum.adOpenForwardOnly, ADODB.LockTypeEnum.adLockOptimistic);
                    rs1.AddNew();
                    rs1.Fields["Anfangsdatum"].Value = ux_EinsatzDatumAnfang.Text;
                    rs1.Fields["Enddatum"].Value = ux_EinsatzDatumEnde.Text;
                    rs1.Fields["ID_Abteilung"].Value = ux_AbteilungenDropDown.SelectedValue.ToString();
                    rs1.Fields["kuerzel_Auszubildender"].Value = Request.QueryString["azubi"];

                    // Schließen der Datenbankverbindung
                    rs1.Update();
                    rs1.Close();
                    _conn1.Close();

                }                
                // Wenn der Einsatz zu einer anderen Abteilung verändert wurde
                else if (ux_AbteilungenDropDown.SelectedValue.ToString() != "Urlaub" && ux_AbteilungenDropDown.SelectedValue.ToString() != abteilung)
                {
                    string anfrage = "SELECT * FROM " + tabelle + " WHERE Anfangsdatum IS NULL ;";
                    rs1.Open(anfrage, _conn1, ADODB.CursorTypeEnum.adOpenForwardOnly, ADODB.LockTypeEnum.adLockOptimistic);
                    rs1.AddNew();
                    rs1.Fields["Anfangsdatum"].Value = ux_EinsatzDatumAnfang.Text;
                    rs1.Fields["Enddatum"].Value = ux_EinsatzDatumEnde.Text;
                    rs1.Fields["ID_Abteilung"].Value = ux_AbteilungenDropDown.SelectedValue.ToString();
                    rs1.Fields["kuerzel_Auszubildender"].Value = Request.QueryString["azubi"];

                    // Schließen der Datenbankverbindung
                    rs1.Update();
                    rs1.Close();
                    _conn1.Close();
                }
            } catch (FormatException)
            {
                ux_FehlermeldungLabel.Visible = true;
                ux_FehlermeldungLabel.Text = "Bitte gültige Daten eingeben";
            }

            ux_idLabel.Text = "";
            ux_saveBtton.Visible = true;
            ux_saveBtton.Enabled = true;
            ux_EditSaveButton.Visible = false;
            ux_EditSaveButton.Enabled = false;           
            AzubiData_Load((int)ViewState["Year"]);
        }

        // Erstellen einer Liste mit allen Feiertagen
        private List<DateTime> FeiertageBerechnen(int year)
        {
            List<DateTime> feiertage = new List<DateTime>();
            feiertage.Add(new DateTime(year, 01, 01)); // Neujahr
            feiertage.Add(new DateTime(year, 03, 08)); // Frauentag
            feiertage.Add(GetEasterFriday(year)); // Karfreitag
            feiertage.Add(GetEasterSunday(year)); // Ostersonntag
            feiertage.Add(GetEasterMonday(year)); // Ostermontag
            feiertage.Add(new DateTime(year, 05, 01)); // Tag der Arbeit
            feiertage.Add(GetAscensionDay(year)); // Christi Himmelfahrt
            feiertage.Add(GetPentecostSunday(year)); // Pfingstsonntag
            feiertage.Add(GetPentecostMonday(year)); // Pfingstmontag
            feiertage.Add(new DateTime(year, 10, 03)); // Tag der Deutschen Einheit
            feiertage.Add(new DateTime(year, 10, 31)); // Reformationstag
            feiertage.Add(new DateTime(year, 12, 24)); // Heilig Abend
            feiertage.Add(new DateTime(year, 12, 25)); // Weihnachtstag
            feiertage.Add(new DateTime(year, 12, 26)); // Zweiter Weihnachtstag
            feiertage.Add(new DateTime(year, 12, 31)); // Silvester

            return feiertage;
        }

        // den Kalender unserer Kultur verwenden um den richtig Monat zu bekommen
        private string GetMonthName(int month)
        {
            return CultureInfo.GetCultureInfo("de-DE").DateTimeFormat.GetMonthName(month);
        }

        // den Kalender unserer Kultur verwenden um den Wochentag zu bekommen
        private string GetDayOfWeek(int year, int month, int day)
        {
            return CultureInfo.GetCultureInfo("de-DE").DateTimeFormat.GetDayName(new DateTime(year, month, day).DayOfWeek);
        }

        // Berechnung des Ostersonntags
        public static DateTime GetEasterSunday(int year)
        {
            //https://dotnet-snippets.de/snippet/ermittlung-von-feiertagen-feiertaglogic/763
            int g, h, c, j, l, i;

            g = year % 19;
            c = year / 100;
            h = ((c - (c / 4)) - (((8 * c) + 13) / 25) + (19 * g) + 15) % 30;
            i = h - (h / 28) * (1 - (29 / (h + 1)) * ((21 - g) / 11));
            j = (year + (year / 4) + i + 2 - c + (c / 4)) % 7;

            l = i - j;
            int month = (int)(3 + ((l + 40) / 44));
            int day = (int)(l + 28 - 31 * (month / 4));

            return new DateTime(year, month, day);
        }

        // Himmelfahrt aus Ostersonntag berechnen
        public static DateTime GetAscensionDay(int year)
        {
            return GetEasterSunday(year).AddDays(39);
        }

        // Pfingstsonntag aus Ostersonntag berechnen
        public static DateTime GetPentecostSunday(int year)
        {
            return GetEasterSunday(year).AddDays(49);
        }

        // Pfingstmontag aus Ostersonntag berechnen
        public static DateTime GetPentecostMonday(int year)
        {
            return GetPentecostSunday(year).AddDays(1);
        }

        // Osterfreitag aus Ostersonntag berechnen
        public static DateTime GetEasterFriday(int year)
        {
            return GetEasterSunday(year).AddDays(-2);
        }

        // Ostermontag aus Ostersonntag berechnen
        public static DateTime GetEasterMonday(int year)
        {
            return GetEasterSunday(year).AddDays(1);
        }
    }
}