using System;
using System.Collections.Generic;
using System.Drawing;
using System.Globalization;
using System.Web.UI.WebControls;


namespace Azubi_Einsatzplaner
{
    public partial class Calender : System.Web.UI.Page
    {
        // Datenbank Connection
        readonly string _gConnectStr = @"Provider=Microsoft.Jet.OLEDB.4.0;Data Source=C:\Temp\Azubi_Einsatzplaner\Azubi_Einsatzplaner.mdb;Persist Security Info=False";
        readonly ADODB.Connection _conn1 = new ADODB.Connection();

        // Farben für die Abwesenheiten
        private Color Wochenende = Color.FromArgb(227, 226, 213);
        private Color Feiertag = Color.FromArgb(0, 173, 204);
        private Color Einsatz = Color.FromArgb(162, 205, 3);

        protected void Page_Init(object sender, EventArgs e)
        {
            // Überprüfen, ob Year-Parameter übergeben wurde
            if (Request.QueryString["year"] != null)
            {
                // Jahr in eine Variable schreiben
                int year = Convert.ToInt32(Request.QueryString["year"]);

                // Zwischenspeichern für Seitenaktualisierungen
                ViewState["Year"] = year;

                // Übersicht laden
                Azubi_Load(year);
                Fachbereiche_Load();
            } else
            {
                // An die GesamtAnsicht weiterleiten
                Response.Redirect("GesamtAnsicht.aspx");
            }
        }
        protected void Page_Load(object sender, EventArgs e)
        {

        }

        // Ausgewählten Azubi auslesen 
        private void Azubi_Load(int year)
        {
 
            if (Request.QueryString["azubi"] != null)
            {
                _conn1.Open(_gConnectStr);
                ADODB.Recordset rs1 = new ADODB.Recordset();
                
                // Informationen des Azubis auslesen und darstellen
                rs1.Open("SELECT * FROM Auszubildender WHERE kuerzel ='" + Request.QueryString["azubi"] + "'", _conn1, ADODB.CursorTypeEnum.adOpenForwardOnly, ADODB.LockTypeEnum.adLockOptimistic);

                ux_vornameLabel.Text = rs1.Fields["Vorname"].Value.ToString();
                ux_nachnameLabel.Text = rs1.Fields["Nachname"].Value.ToString();
                ux_fachrichtungLabel.Text = rs1.Fields["Fachrichtung"].Value.ToString();
                ux_jahrgangLabel.Text = rs1.Fields["Jahrgang"].Value.ToString();
                ux_turnusLabel.Text = rs1.Fields["Turnus"].Value.ToString();

                // Schließen der Datenbankverbindung
                rs1.Close();
                _conn1.Close();

                CreateCalendar(year);
            }
            else
            {
                // An die GesamtAnsicht weiterleiten
                Response.Redirect("GesamtAnsicht.aspx");
            }
        }

        // Fachbereiche in das DropDown schreiben
        private void Fachbereiche_Load()
        {
            _conn1.Open(_gConnectStr);
            ADODB.Recordset rs1 = new ADODB.Recordset();

            // Alle Abteilungen auslesen und in Dropdown schreiben
            rs1.Open("SELECT * FROM Abteilung;", _conn1, ADODB.CursorTypeEnum.adOpenForwardOnly, ADODB.LockTypeEnum.adLockOptimistic);

            ux_AbteilungenDropDown.Items.Add(new ListItem(""));
            while (!rs1.EOF)
            {
                ux_AbteilungenDropDown.Items.Add(new ListItem(rs1.Fields["Abteilung"].Value.ToString()));
                rs1.MoveNext();
            }

            // Schließen der Datenbankverbindung
            rs1.Close();
            _conn1.Close();
        }

        // Das ausgewählte Jahr vermindern und dann anzeigen
        protected void ux_previousYearButton_Click(object sender, EventArgs e)
        {
            // Jahresvariable aus dem Viewstate entnehmen und neu speichern
            int year = (int)ViewState["Year"];
            year--;
            ViewState["Year"] = year;
            CreateCalendar(year);
        }

        // Das ausgewählte Jahr erhöhen und dann anzeigen
        protected void ux_nextYearButton_Click(object sender, EventArgs e)
        {
            // Jahresvariable aus dem Viewstate entnehmen und neu speichern
            int year = (int)ViewState["Year"];
            year++;
            ViewState["Year"] = year;
            CreateCalendar(year);
        }

        // Kalenderansicht erstellen (Alle Tage im Jahr)
        private void CreateCalendar(int year)
        {            
            List<DateTime> feiertage = FeiertageBerechnen(year);
            List<Einsatz> einsaetze = GetEinsaetze();

            // Vorherige Anzeigen löschen
            ux_calendarTable.Rows.Clear();

            // Ausgewähltes Jahr darstellen
            ux_todaysYearLabel.Text = year.ToString();

            // Überschriften für die Spalten der Monate
            TableRow headerRow = new TableRow();
            for (int month = 1; month <= 12; month++)
            {
                TableCell headerCell = new TableCell();
                CheckBox checkBox = new CheckBox();

                checkBox.ID = month.ToString();
                checkBox.Text = GetMonthName(month);
                checkBox.Font.Bold = true;
                headerCell.Controls.Add(checkBox);

                headerCell.BackColor = Color.FromArgb(4, 149, 197);
                headerCell.HorizontalAlign = HorizontalAlign.Center;
                headerRow.Cells.Add(headerCell);
            }
            ux_calendarTable.Rows.Add(headerRow);

            // Reihen für jeden Tag erstellen
            for (int day = 1; day <= 31; day++)
            {
                TableRow dayRow = new TableRow();

                // Jede Spalte der Monate durchgehen
                for (int month = 1; month <= 12; month++)
                {
                    TableCell dayCell = new TableCell();

                    //Überprüfen ob Reihenzahl noch innerhalb der Anzahl der Tage im Monat liegt
                    if (day <= DateTime.DaysInMonth(year, month))
                    {
                        //Datum in die Zelle schreiben
                        DateTime todaysDate = new DateTime(year, month, day);
                        String dayOfWeek = GetDayOfWeek(year, month, day);
                        dayCell.Text = day + " " + dayOfWeek.Substring(0, 3);

                        // Einsätze farbig markieren
                        foreach (Einsatz einsatz in einsaetze)
                        {
                            if (einsatz.Datum == todaysDate)
                            {
                                dayCell.BackColor = Einsatz;

                                if (einsatz.Abteilung.Length > 3)
                                {
                                    dayCell.Text += " (" + einsatz.Abteilung.Substring(0, 3) + ")";
                                } else
                                {
                                    dayCell.Text += " (" + einsatz.Abteilung + ")";
                                }
                                
                            }
                        }

                        // Feiertage farbig markieren
                        foreach (DateTime datum in feiertage)
                        {
                            if (datum == todaysDate)
                            {
                                dayCell.BackColor = Feiertag;
                                dayCell.Text = day + " " + dayOfWeek.Substring(0, 3);
                            }
                        }

                        // Wochenenden farbig markieren
                        if (dayOfWeek == "Sunday" || dayOfWeek == "Saturday")
                        {
                            dayCell.BackColor = Wochenende;
                            dayCell.Text = day + " " + dayOfWeek.Substring(0, 3);
                        }
                    }

                    dayCell.HorizontalAlign = HorizontalAlign.Center;
                    dayRow.Cells.Add(dayCell);
                }
                ux_calendarTable.Rows.Add(dayRow);
            }
        }

        // den Kalender unserer Kultur verwenden um den richtig Monat zu bekommen
        private string GetMonthName(int month)
        {
            return CultureInfo.InvariantCulture.DateTimeFormat.GetMonthName(month);
        }

        // den Kalender unserer Kultur verwenden um den Wochentag zu bekommen
        private string GetDayOfWeek(int year, int month, int day)
        {
            return CultureInfo.InvariantCulture.DateTimeFormat.GetDayName(new DateTime(year, month, day).DayOfWeek);
        }

        // Liste der Einsätze erstellen
        private List<Einsatz> GetEinsaetze()
        {
            List<Einsatz> einsaetze = new List<Einsatz>();
            DateTime anfangsdatum;
            DateTime enddatum;

            _conn1.Open(_gConnectStr);
            ADODB.Recordset rs1 = new ADODB.Recordset();

            // Alle Einsätze des ausgewählten Azubis abrufen
            rs1.Open("SELECT * FROM Einsatz WHERE kuerzel_Auszubildender = '" + Request.QueryString["azubi"] + "';", _conn1, ADODB.CursorTypeEnum.adOpenForwardOnly, ADODB.LockTypeEnum.adLockOptimistic);

            while (!rs1.EOF)
            {
                anfangsdatum = rs1.Fields["Anfangsdatum"].Value;
                enddatum = rs1.Fields["Enddatum"].Value;
                string abteilung = rs1.Fields["ID_Abteilung"].Value.ToString();

                // Die Tage zwischen Anfangs- und Enddatum erstellen und zu einer Liste hinzufügen
                // So können alle Tage des Einsatzes markiert werden
                for (DateTime date = anfangsdatum; date <= enddatum; date = date.AddDays(1))
                {
                    Einsatz einsatz = new Einsatz();
                    einsatz.Datum = date;
                    einsatz.Abteilung = abteilung;
                    einsaetze.Add(einsatz);
                }

                rs1.MoveNext();
            }

            // Schließen der Datenbankverbindung
            rs1.Close();
            _conn1.Close();

            return einsaetze;
        }

        // Erstellen einer Liste mit allen Feiertagen
        private List<DateTime> FeiertageBerechnen(int year)
        {
            List<DateTime> feiertage = new List<DateTime>();
            feiertage.Add(new DateTime(year, 01, 01)); // Neujahr
            feiertage.Add(new DateTime(year, 03, 08)); // Frauentag
            feiertage.Add(GetEasterFriday(year)); // Karfreitag
            feiertage.Add(GetEasterSunday(year)); // Ostersonntag
            feiertage.Add(GetEasterMonday(year)); // Ostermontag
            feiertage.Add(new DateTime(year, 05, 01)); // Tag der Arbeit
            feiertage.Add(GetAscensionDay(year)); // Christi Himmelfahrt
            feiertage.Add(GetPentecostSunday(year)); // Pfingstsonntag
            feiertage.Add(GetPentecostMonday(year)); // Pfingstmontag
            feiertage.Add(new DateTime(year, 10, 03)); // Tag der Deutschen Einheit
            feiertage.Add(new DateTime(year, 10, 31)); // Reformationstag
            feiertage.Add(new DateTime(year, 12, 24)); // Heilig Abend
            feiertage.Add(new DateTime(year, 12, 25)); // Weihnachtstag
            feiertage.Add(new DateTime(year, 12, 26)); // Zweiter Weihnachtstag
            feiertage.Add(new DateTime(year, 12, 31)); // Silvester

            return feiertage;
        }

        // Berechnung des Ostersonntags
        public static DateTime GetEasterSunday(int year)
        {
            //https://dotnet-snippets.de/snippet/ermittlung-von-feiertagen-feiertaglogic/763
            int g, h, c, j, l, i;

            g = year % 19;
            c = year / 100;
            h = ((c - (c / 4)) - (((8 * c) + 13) / 25) + (19 * g) + 15) % 30;
            i = h - (h / 28) * (1 - (29 / (h + 1)) * ((21 - g) / 11));
            j = (year + (year / 4) + i + 2 - c + (c / 4)) % 7;

            l = i - j;
            int month = (int)(3 + ((l + 40) / 44));
            int day = (int)(l + 28 - 31 * (month / 4));

            return new DateTime(year, month, day);
        }

        // Himmelfahrt aus Ostersonntag berechnen
        public static DateTime GetAscensionDay(int year)
        {
            return GetEasterSunday(year).AddDays(39);
        }

        // Pfingstsonntag aus Ostersonntag berechnen
        public static DateTime GetPentecostSunday(int year)
        {
            return GetEasterSunday(year).AddDays(49);
        }

        // Pfingstmontag aus Ostersonntag berechnen
        public static DateTime GetPentecostMonday(int year)
        {
            return GetPentecostSunday(year).AddDays(1);
        }

        // Osterfreitag aus Ostersonntag berechnen
        public static DateTime GetEasterFriday(int year)
        {
            return GetEasterSunday(year).AddDays(-2);
        }

        // Ostermontag aus Ostersonntag berechnen
        public static DateTime GetEasterMonday(int year)
        {
            return GetEasterSunday(year).AddDays(1);
        }
    }
}