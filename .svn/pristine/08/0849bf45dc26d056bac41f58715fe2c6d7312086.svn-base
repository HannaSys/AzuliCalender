.calendar {
    width: 100%;
    border-collapse: collapse;
}

    .calendar th, .calendar td {
        border: 1px solid #ccc;
        padding: 5px;
        text-align: center;
    }

    .calendar th {
        background-color: #f0f0f0;
    }